set_multicycle_path 2 -setup -from [get_cells [list {VoxLink_I2C_Driver_inst.i2c_state[7] VoxLink_I2C_Driver_inst.i2c_state[6] VoxLink_I2C_Driver_inst.i2c_state[5] VoxLink_I2C_Driver_inst.i2c_state[4] VoxLink_I2C_Driver_inst.i2c_state[3] VoxLink_I2C_Driver_inst.i2c_state[2] VoxLink_I2C_Driver_inst.i2c_state[1] VoxLink_I2C_Driver_inst.i2c_state[0]}]]
